{
  "name": "@taxi/request-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Taxi customer-facing frontend for creating HelpRequests (Angular + DB UX).",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "pnpm start",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:styles": "pnpm exec stylelint \"src/**/*.{css,scss}\"",
    "format": "pnpm exec prettier --write src"
  },
  "dependencies": {
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/localize": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/platform-browser-dynamic": "21.2.14",
    "@angular/router": "21.2.14",
    "@angular/service-worker": "21.2.14",
    "@db-ux/core-components": "4.9.1",
    "@db-ux/core-foundations": "4.9.1",
    "@db-ux/db-theme": "5.7.0",
    "@db-ux/db-theme-fonts": "2.0.5",
    "@db-ux/db-theme-icons": "3.9.0",
    "@db-ux/ngx-core-components": "4.9.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "@angular/language-service": "21.2.14",
    "@db-ux/core-stylelint": "4.9.1",
    "@double-great/stylelint-a11y": "3.4.13",
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.4",
    "@typescript-eslint/scope-manager": "8.59.4",
    "@vitest/coverage-v8": "4.1.7",
    "angular-eslint": "21.4.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jsdom": "29.1.1",
    "postcss-angular": "2.0.0",
    "prettier": "3.8.3",
    "prettier-eslint": "16.4.2",
    "stylelint": "16.26.1",
    "stylelint-config-standard-scss": "16.0.0",
    "stylelint-use-logical": "2.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  }
