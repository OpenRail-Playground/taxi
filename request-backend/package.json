{
  "name": "@taxi/request-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Taxi backend (NestJS on Express) for creating and managing HelpRequest entities.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "11.1.7",
    "@nestjs/core": "11.1.7",
    "@nestjs/platform-express": "11.1.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@nestjs/schematics": "11.0.7",
    "@types/express": "5.0.5",
    "@types/node": "24.12.4",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  }
